rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Incidents: authenticated users can read, only backend (Cloud Run) writes via Admin SDK
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      // Authenticated users can update only the responders map or the status field
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responders', 'status']);
      // Authenticated users can create MESSAGE-type incidents
      allow create: if request.auth != null
        && request.resource.data.incidentType in ['MESSAGE', 'PRIORITY TRAFFIC'];
    }

    // User profiles: any authenticated user can read (for custom statuses),
    // but only the owner can write their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Calendar events: any authenticated user can create their own events and RSVP;
    // only the creator can update content or cancel.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy;
      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.createdBy
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees'])
        );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // Config: authenticated users can read (on-call data, etc.)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
  }
}
