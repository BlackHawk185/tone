rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Incidents: authenticated users can read, only backend (Cloud Run) writes via Admin SDK
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      // Authenticated users can update only the responders map or the status field
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responders', 'status']);
      // Authenticated users can create MESSAGE-type incidents
      allow create: if request.auth != null
        && request.resource.data.incidentType in ['MESSAGE', 'PRIORITY TRAFFIC'];
    }

    // User profiles: users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Config: authenticated users can read (on-call data, etc.)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
  }
}
