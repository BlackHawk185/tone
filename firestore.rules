rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Unified feed collection — dispatches, messages, and calendar events.
    match /feed/{docId} {
      allow read: if request.auth != null;

      // Authenticated users can create MESSAGE or EVENT docs only.
      // DISPATCH docs are written exclusively by the backend Admin SDK.
      allow create: if request.auth != null
        && (
          request.resource.data.type == 'MESSAGE'
          || (
            request.resource.data.type == 'EVENT'
            && request.auth.uid == request.resource.data.createdBy
          )
        );

      allow update: if request.auth != null
        && (
          // Responder status updates on dispatches
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['responders', 'status'])
          // Event creator can update any field on their event
          || (resource.data.type == 'EVENT'
              && request.auth.uid == resource.data.createdBy)
          // Any authenticated user can RSVP on an event
          || (resource.data.type == 'EVENT'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['attendees']))
        );

      // Only event creators can delete their own events
      allow delete: if request.auth != null
        && resource.data.type == 'EVENT'
        && request.auth.uid == resource.data.createdBy;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Config (on-call, etc.) — Admin SDK writes only
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
