# Google OAuth credentials for the Tone service account.
# The refresh token must be minted with both Gmail modify and Calendar readonly scopes.
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_ACCOUNT_EMAIL=tone.pinebluffsems@gmail.com

# Google API listeners
PUBSUB_TOPIC=projects/your-project/topics/gmail-push
PUSH_SECRET=replace_with_random_secret
PUBLIC_BASE_URL=https://tone-dispatch-listener-323826101860.us-central1.run.app

# Calendar sync
CALENDAR_ID=primary
CALENDAR_WATCH_TTL_SECONDS=604800
SHIFT_LOOKBACK_HOURS=36
SHIFT_LOOKAHEAD_HOURS=36

# Firebase
FIREBASE_PROJECT_ID=tone-b66eb
